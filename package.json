{
  "name": "stress-fullstack",
  "private": true,
  "version": "1.0.0",
  "description": "O Stress Kalaana — fullstack (React frontend + Express/MongoDB backend) for the Wall of Confession.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n frontend,backend,admin -c cyan,magenta,yellow \"npm:dev:frontend\" \"npm:dev:backend\" \"npm:dev:admin\"",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix server run dev",
    "dev:admin": "npm --prefix admin run dev",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "npm --prefix server run seed",
    "install:all": "npm install && npm --prefix server install && npm --prefix admin install"
  },
  "dependencies": {
    "bad-words": "^4.0.0",
    "clsx": "2.1.1",
    "firebase": "^12.15.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/bad-words": "^3.0.3",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "concurrently": "^10.0.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0"
  },
  "workspaces": [],
  "engines": {
    "node": ">=18"
  }
}
