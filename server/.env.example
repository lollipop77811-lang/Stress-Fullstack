# Server config
PORT=5000

# MongoDB Atlas connection string.
# Get this from Atlas → Connect → Drivers → Node.js.
# Replace <user>, <password>, <cluster>, <db> with your values.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/stress_kalaana?retryWrites=true&w=majority"

# Comma-separated list of allowed CORS origins.
# In dev: leave blank to allow all origins.
# In prod: set to your deployed frontend URL, e.g.
#   CORS_ORIGIN="https://your-frontend.vercel.app,https://your-custom-domain.com"
CORS_ORIGIN=""

# Firebase Admin SDK — for authentication (email + Google)
# Option A: Save the service account JSON as "firebase-service-account.json"
#           in the server/ directory (gitignored).
# Option B: Set this env var to the JSON string (for production):
# FIREBASE_SERVICE_ACCOUNT='{ "type": "service_account", "project_id": "...", ... }'
